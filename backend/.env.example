# =============================================
#  OmniSync 后端配置
#  复制此文件为 .env 并填入真实凭证
# =============================================

# ---- 发布模式 ----
# true = 真实发布到各平台（需要配置下方凭证）
# false = 模拟模式（开发测试用，默认）
LIVE_MODE=false

# ---- 公众号 (WeChat) ----
# 申请地址: https://mp.weixin.qq.com → 开发 → 基本配置
WECHAT_APP_ID=你的公众号AppID
WECHAT_APP_SECRET=你的公众号AppSecret
WECHAT_ACCESS_TOKEN=你的AccessToken（可选，不填则用AppID+AppSecret自动获取）

# ---- 知乎 (Zhihu) ----
# 需要知乎开放平台开发者账号或Cookie登录态
ZHIHU_ACCESS_TOKEN=你的知乎Token

# ---- B站 (Bilibili) ----
# 申请地址: https://open.bilibili.com
BILIBILI_APP_ID=B站AppKey
BILIBILI_APP_SECRET=B站AppSecret
BILIBILI_ACCESS_TOKEN=B站Access Token

# ---- 小红书 (Xiaohongshu) ----
# 需要小红书创作者平台凭证
XIAOHONGSHU_ACCESS_TOKEN=小红书Token
